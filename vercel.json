{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "ard.via51.org"
        }
      ],
      "destination": "/internal-holding/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pol.via51.org"
        }
      ],
      "destination": "/political-branch/$1"
    }
  ]
}
